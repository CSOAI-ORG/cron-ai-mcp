{
  "name": "cron-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs MCP Server",
  "version": "1.0.0",
  "tools": [
    {
      "name": "parse_cron",
      "description": "Parse a cron expression into its components with validation.",
      "parameters": {
        "type": "object",
        "properties": {
          "expression": {
            "type": "string"
          }
        },
        "required": [
          "expression"
        ]
      }
    },
    {
      "name": "generate_cron",
      "description": "Generate a cron expression. Use preset for common schedules: every_5min, every_hour, daily_midnight, weekly_monday, monthly_first, weekdays_9am.",
      "parameters": {
        "type": "object",
        "properties": {
          "minute": {
            "type": "string"
          },
          "hour": {
            "type": "string"
          },
          "day_of_month": {
            "type": "string"
          },
          "month": {
            "type": "string"
          },
          "day_of_week": {
            "type": "string"
          },
          "preset": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "next_runs",
      "description": "Calculate next N run times for a cron expression.",
      "parameters": {
        "type": "object",
        "properties": {
          "expression": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "from_date": {
            "type": "string"
          }
        },
        "required": [
          "expression"
        ]
      }
    },
    {
      "name": "explain_cron",
      "description": "Explain a cron expression in human-readable English.",
      "parameters": {
        "type": "object",
        "properties": {
          "expression": {
            "type": "string"
          }
        },
        "required": [
          "expression"
        ]
      }
    }
  ]
}